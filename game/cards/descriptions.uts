export function getCardDescription(cardId : string) : string {
  const desc = DESCRIPTION_MAP.get(cardId)
  return desc != null ? desc : '暂无效果说明'
}

export function getCardTypeLabel(cardType : string) : string {
  if (cardType == 'attack') return '攻击'
  if (cardType == 'trigger') return '触发'
  if (cardType == 'continuous') return '持续'
  return cardType
}

export function getCardTypeIcon(cardType : string) : string {
  if (cardType == 'attack') return '△'
  if (cardType == 'trigger') return '⚡'
  if (cardType == 'continuous') return '●'
  return ''
}

export function getEmblemLabel(emblem : string) : string {
  if (emblem == 'crown') return '皇室'
  if (emblem == 'dragon') return '魔龙'
  if (emblem == 'demon') return '魔王'
  return ''
}
